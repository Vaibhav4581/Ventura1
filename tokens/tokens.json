{
  "$description": "Ventura Builders & Developers design tokens. W3C Design Tokens Community Group format (stable spec, 2025.10). Tiers: primitive -> semantic. Consumable by Style Dictionary; mirrored in app/globals.css.",
  "color": {
    "$type": "color",
    "navy": {
      "900": { "$value": "#0f1535", "$description": "Ink / deep navy — body text" },
      "800": { "$value": "#162058" },
      "700": { "$value": "#1b2c7a", "$description": "Brand navy (logo)" },
      "600": { "$value": "#243a8f" },
      "500": { "$value": "#2e49a8" }
    },
    "blue": {
      "600": { "$value": "#0f62c7", "$description": "Link-safe blue (AA on white)" },
      "500": { "$value": "#0087ff", "$description": "Signature accent blue" },
      "100": { "$value": "#e6f2ff" }
    },
    "amber": {
      "700": { "$value": "#c2710a" },
      "600": { "$value": "#e07e0a", "$description": "CTA hover" },
      "500": { "$value": "#f7941d", "$description": "Brand amber (hard hat)" },
      "100": { "$value": "#fdebd3" }
    },
    "neutral": {
      "0": { "$value": "#ffffff" },
      "50": { "$value": "#f5f7fb", "$description": "Mist — alt section bg" },
      "100": { "$value": "#eceff6" },
      "200": { "$value": "#dfe4ef", "$description": "Border / hairline" },
      "300": { "$value": "#c6cddd" },
      "400": { "$value": "#9aa3bb" },
      "600": { "$value": "#4c5670", "$description": "Muted text (AA on white)" },
      "800": { "$value": "#232b45" }
    },
    "state": {
      "success": { "$value": "#15803d" },
      "warning": { "$value": "#b45309" },
      "error": { "$value": "#c02b1d" }
    }
  },
  "semantic": {
    "color": {
      "$type": "color",
      "bg": { "$value": "{color.neutral.0}" },
      "bg-alt": { "$value": "{color.neutral.50}" },
      "bg-invert": { "$value": "{color.navy.700}" },
      "text": { "$value": "{color.navy.900}" },
      "text-muted": { "$value": "{color.neutral.600}" },
      "border": { "$value": "{color.neutral.200}" },
      "primary": { "$value": "{color.navy.700}" },
      "accent": { "$value": "{color.blue.500}" },
      "link": { "$value": "{color.blue.600}" },
      "cta": { "$value": "{color.amber.500}" },
      "on-cta": { "$value": "{color.navy.900}", "$description": "Navy on amber = AA; white on amber fails" }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$value": ["Montserrat", "Segoe UI", "system-ui", "sans-serif"] },
      "body": { "$value": ["Inter", "system-ui", "-apple-system", "sans-serif"] }
    },
    "size": {
      "$type": "dimension",
      "$description": "Major-Third (1.25) modular scale, base 16px",
      "caption": { "$value": "0.8125rem" },
      "small": { "$value": "0.875rem" },
      "body": { "$value": "1rem" },
      "body-lg": { "$value": "1.125rem" },
      "h6": { "$value": "1.25rem" },
      "h5": { "$value": "1.5625rem" },
      "h4": { "$value": "1.953rem" },
      "h3": { "$value": "2.441rem" },
      "h2": { "$value": "3.052rem" },
      "h1": { "$value": "3.815rem" },
      "display": { "$value": "4.768rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 },
      "extrabold": { "$value": 800 }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "8-pt grid with a 4px half-step",
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.5rem" },
    "6": { "$value": "2rem" },
    "7": { "$value": "3rem" },
    "8": { "$value": "4rem" },
    "9": { "$value": "5rem" },
    "10": { "$value": "6rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "10px" },
    "lg": { "$value": "16px" },
    "xl": { "$value": "24px" },
    "pill": { "$value": "999px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": { "offsetX": "0", "offsetY": "1px", "blur": "3px", "spread": "0", "color": "rgba(15,21,53,0.10)" } },
    "md": { "$value": { "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "0", "color": "rgba(15,21,53,0.08)" } },
    "lg": { "$value": { "offsetX": "0", "offsetY": "12px", "blur": "32px", "spread": "0", "color": "rgba(15,21,53,0.12)" } }
  },
  "duration": {
    "$type": "duration",
    "fast": { "$value": "150ms" },
    "base": { "$value": "250ms" },
    "slow": { "$value": "400ms" }
  }
}
